# =============================================================================
# Variables de entorno - Proyecto B (Control de Asistencias)
# Apartado 7.1 del Manual de Programación Flutter (MPF)
# -----------------------------------------------------------------------------
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NUNCA debe subirse al repositorio (ver .gitignore).
# =============================================================================

# URL base del API REST del sistema (Heroku / hosting nube — entrevista 00:23)
API_BASE_URL=https://api.ejemplo.com

# Autenticación
TOKEN_TTL_MINUTES=15

# PayPal Sandbox (RF-15 — pasarela de pagos)
PAYPAL_CLIENT_ID=changeme
PAYPAL_SECRET=changeme
PAYPAL_ENV=sandbox

# Notificaciones push (RF-10 / RF-11 / RF-12)
FCM_SERVER_KEY=changeme

# Ambiente actual: dev | staging | prod
APP_ENV=dev

# Habilita / deshabilita logs detallados
ENABLE_VERBOSE_LOGS=true
